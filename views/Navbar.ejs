<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/output.css">
  <title>Navbar</title>
</head>

<body>

<!-- NAVBAR -->
<nav class="bg-white shadow-md sticky top-0 z-50">

  <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">

    <!-- LOGO -->
    <div class="text-2xl font-bold text-blue-600">
      🛒 Perfect Solution
    </div>

    <!-- MENU -->
    <ul class="hidden md:flex gap-6 font-medium items-center">

      <li>
        <a href="/"
          class="transition hover:text-blue-600 <%= active === 'home' ? 'text-blue-600 font-bold' : 'text-gray-700' %>">
          Home
        </a>
      </li>

      <li>
        <a href="/about"
          class="transition hover:text-blue-600 <%= active === 'about' ? 'text-blue-600 font-bold' : 'text-gray-700' %>">
          About
        </a>
      </li>

      <li>
        <a href="/products"
          class="transition hover:text-blue-600 <%= active === 'products' ? 'text-blue-600 font-bold' : 'text-gray-700' %>">
          Products
        </a>
      </li>

      <li>
        <a href="/contact"
          class="transition hover:text-blue-600 <%= active === 'contact' ? 'text-blue-600 font-bold' : 'text-gray-700' %>">
          Contact
        </a>
      </li>

      <li>
        <a href="/favorites"
          class="transition hover:text-blue-600 <%= active === 'favorites' ? 'text-blue-600 font-bold' : 'text-gray-700' %>">
          Favorites
        </a>
      </li>

      <li>
        <a href="/login"
          class="px-4 py-1 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">
          Login
        </a>
      </li>

    </ul>

    <!-- MOBILE MENU ICON -->
    <div class="md:hidden text-2xl cursor-pointer">
      ☰
    </div>

  </div>

</nav>

</body>
</html>