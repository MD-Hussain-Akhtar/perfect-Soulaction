<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="./output.css">
    <title>Document</title>
</head>
<body>

<!-- NAVBAR -->
<nav class="bg-white shadow-md">

  <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">

    <!-- LOGO -->
    <div class="text-2xl font-bold text-blue-600">
      🛒 Perfect Soluction
    </div>

    <!-- MENU -->
    <ul class="hidden md:flex gap-6 font-medium">

      <li>
        <a href="/"
          class="hover:text-blue-600 transition <%= active === 'Home' ? 'text-blue-600 font-bold' : 'text-gray-700' %>">
          Home
        </a>
      </li>

      <li>
        <a href="/about"
          class="hover:text-blue-600 transition <%= active === 'About' ? 'text-blue-600 font-bold' : 'text-gray-700' %>">
          About
        </a>
      </li>

      <li>
        <a href="/products"
          class="hover:text-blue-600 transition <%= active === 'Products' ? 'text-blue-600 font-bold' : 'text-gray-700' %>">
          Products
        </a>
      </li>

      <li>
        <a href="/contact"
          class="hover:text-blue-600 transition <%= active === 'Contact' ? 'text-blue-600 font-bold' : 'text-gray-700' %>">
          Contact
        </a>
      </li>

      <li>
        <a href="/login-author"
          class="px-4 py-1 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">
          Login
        </a>
      </li>

    </ul>

    <!-- MOBILE BUTTON (simple) -->
    <div class="md:hidden text-2xl">☰</div>

  </div>

</nav>

</body>
</html>