<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>product Deatils</title>
  <link rel="stylesheet" href="/output.css">
 <style>
    .flip-container {
      perspective: 1000px;
    }

    .flip-inner {
      transition: transform 0.8s;
      transform-style: preserve-3d;
      position: relative;
    }

    .flip-container:hover .flip-inner {
      transform: rotateY(180deg);
    }

    .flip-front, .flip-back {
      backface-visibility: hidden;
      position: absolute;
      width: 100%;
      height: 100%;
      border-radius: 20px;
    }

    .flip-back {
      transform: rotateY(180deg);
    }
  </style>
</head>

<body class="bg-gray-100 flex items-center justify-center min-h-screen">

<div class="w-full max-w-3xl h-[500px] flip-container">

  <div class="flip-inner w-full h-full">

    <!-- FRONT SIDE -->
    <div class="flip-front bg-white shadow-2xl p-6 flex flex-col items-center justify-center">

      <img src="<%= product.imageUrl %>" class="w-72 h-72 object-cover rounded-xl shadow">

      <h1 class="text-2xl font-bold mt-4">
        <%= product.productName %>
      </h1>

      <p class="text-green-600 font-bold text-xl mt-2">
        ₹<%= product.price %>
      </p>

      <p class="text-gray-500 mt-2">
        Hover to see details 🔄
      </p>

    </div>

    <!-- BACK SIDE -->
    <div class="flip-back bg-white shadow-2xl p-6 flex flex-col justify-center">

      <h1 class="text-2xl font-bold mb-2">
        <%= product.productName %>
      </h1>

      <p class="text-gray-600 mb-4">
        <%= product.longDescription %>
      </p>

      <p class="text-green-600 font-bold text-xl mb-4">
        ₹<%= product.price %>
      </p>

      <!-- Buttons -->
      <div class="flex flex-col gap-3">

        <button class="bg-blue-500 hover:bg-blue-600 text-white py-2 rounded-xl">
          Buy Now
        </button>

        <button class="bg-gray-200 hover:bg-gray-300 text-black py-2 rounded-xl">
          Add to Cart
        </button>

        <!-- WhatsApp Button -->
       <a 
  href="https://wa.me/918226939049?text=Hi%20I%20want%20to%20buy%20this%20product%0A%0AProduct%20Name:%20<%= product.productName %>%0APrice:%20₹<%= product.price %>%0ADescription:%20<%= product.longDescription %><%= product.imageUrl %>"
  target="_blank"
  class="bg-green-500 hover:bg-green-600 text-white py-2 rounded-xl text-center"
>
  💬 WhatsApp Order
</a>

      </div>

    </div>

  </div>
</div>

</body>
</html>