<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body class="bg-gray-100">

  <%- include('Navbar') %>

  <!-- HERO SECTION -->
  <div class="text-center mt-12 px-4">

    <h1 class="text-4xl font-bold text-gray-800">
      Welcome to 🛒 Perfect Soluction
    </h1>

    <p class="text-gray-500 mt-3 max-w-2xl mx-auto">
      Shopa is your one-stop destination for laptops, gadgets, and modern tech.
      We provide high-quality products at the best prices with fast delivery and trusted service.
    </p>

  </div>

  <!-- FEATURE BOXES -->
  <div class="max-w-6xl mx-auto mt-12 grid grid-cols-1 md:grid-cols-3 gap-6 px-4">

    <div class="bg-white p-6 rounded-xl shadow hover:shadow-lg transition text-center">
      💻
      <h2 class="font-bold text-xl mt-2">Best Laptops</h2>
      <p class="text-gray-500 text-sm mt-1">Top branded laptops at affordable prices.</p>
    </div>

    <div class="bg-white p-6 rounded-xl shadow hover:shadow-lg transition text-center">
      🚚
      <h2 class="font-bold text-xl mt-2">Fast Delivery</h2>
      <p class="text-gray-500 text-sm mt-1">Quick and safe delivery to your doorstep.</p>
    </div>

    <div class="bg-white p-6 rounded-xl shadow hover:shadow-lg transition text-center">
      🔒
      <h2 class="font-bold text-xl mt-2">Secure Shopping</h2>
      <p class="text-gray-500 text-sm mt-1">100% safe and trusted payment system.</p>
    </div>

  </div>

  <!-- ABOUT BANNER -->
  <div class="max-w-6xl mx-auto mt-12 bg-blue-600 text-white p-10 rounded-2xl text-center shadow-lg">

    <h2 class="text-2xl font-bold">Why Choose Shopa?</h2>

    <p class="mt-3 text-gray-100">
      We combine technology, trust, and quality to give you the best online shopping experience.
    </p>

  </div>

  <!-- FOOTER -->
  <footer class="bg-black text-white text-center p-4 mt-10">
    © 2026 Shopa | All Rights Reserved
  </footer>

