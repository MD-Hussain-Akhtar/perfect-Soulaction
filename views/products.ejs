<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/public/output.css">
    <title>Document</title>
</head>
<body>
    <%- include('Navbar')%>
   <div class="min-h-screen bg-gray-100 p-6">

  <h1 class="text-3xl font-bold text-center mb-8">Products</h1>

  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">

    <% newData.forEach((item) => { %>

      <div class="bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-xl transition">

        <!-- Image -->
        <img src="<%= item.imageUrl %>" 
             alt="product"
             class="w-full h-48 object-cover">

        <!-- Content -->
        <div class="p-4">

          <h2 class="text-xl font-semibold text-gray-800">
            <%= item.productName %>
          </h2>

          <p class="text-gray-500 text-sm mt-1">
            <%= item.description %>
          </p>

          <div class="flex justify-between items-center mt-4">

            <span class="text-green-600 font-bold text-lg">
              ₹<%= item.price %>
            </span>
            <a href="/products/<%= item.id %>" class="text-blue-500 hover:underline">
             <button class="bg-gray-300 text-gray-700 px-4 py-1 rounded-lg hover:bg-gray-400">
               View Details
             </button>
            </a>

            <div class="">
             <%- include('add-to-favorites', { product: item }) %>
            </div>

          </div>

        </div>
      </div>

    <% }) %>

  </div>
</div>
</body>
</html>