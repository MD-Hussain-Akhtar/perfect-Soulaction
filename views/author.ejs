<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- FIXED CSS PATH -->
  <link rel="stylesheet" href="/output.css">

  <title>author</title>
</head>

<body class="bg-gray-100">

  <!-- NAVBAR -->
  <%- include('Navbar') %>

  <!-- TITLE -->
  <h1 class="text-3xl font-bold text-center my-6 text-gray-800">
    Author Product Page
  </h1>

  <!-- FORM -->
  <div class="max-w-lg mx-auto bg-white p-6 rounded-2xl shadow-lg">

    <form action="/author" method="post" class="space-y-5">

      <input type="text" name="productName" placeholder="Product Name"
        class="w-full p-3 border rounded-lg" required>

      <textarea name="description" placeholder="Description"
        class="w-full p-3 border rounded-lg" required></textarea>

      <input type="number" name="price" placeholder="Price"
        class="w-full p-3 border rounded-lg" required>

      <input type="text" name="imageUrl" placeholder="Image URL"
        class="w-full p-3 border rounded-lg" required>

      <button class="w-full bg-blue-600 text-white py-3 rounded-lg hover:bg-blue-700">
        Add Product
      </button>

    </form>
  </div>

  <!-- PRODUCTS -->
  <div class="max-w-6xl mx-auto mt-10 p-4">

    <h2 class="text-2xl font-bold mb-6 text-center">Products</h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">

      <% newData.forEach(item => { %>

        <div class="bg-white rounded-xl shadow hover:shadow-xl transition">

          <!-- IMAGE -->
          <img src="<%= item.imageUrl %>" class="h-48 w-full object-cover rounded-t-xl">

          <!-- CONTENT -->
          <div class="p-4">

            <h3 class="text-lg font-bold">
              <%= item.hoseName || item.productName %>
            </h3>

            <p class="text-gray-500 text-sm mt-1">
              <%= item.DESCRIPTION || item.description %>
            </p>

            <div class="flex justify-between mt-4">
              <span class="text-green-600 font-bold">
                ₹<%= item.price %>
              </span>
            </div>

            <!-- BUTTONS -->
            <div class="flex justify-between mt-4">

              <a href="/delete/<%= item.id %>"
                class="bg-red-500 text-white px-3 py-1 rounded hover:bg-red-600">
                Delete
              </a>

              <a href="/edit/<%= item.id %>"
                class="bg-yellow-500 text-white px-3 py-1 rounded hover:bg-yellow-600">
                Edit
              </a>

            </div>

          </div>
        </div>

      <% }) %>

    </div>
  </div>

</body>
</html>