<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>
</head>
<body class="bg-gray-100">

  <%- include('Navbar') %>

  <!-- HEADER -->
  <div class="text-center mt-10">
    <h1 class="text-4xl font-bold text-gray-800">Contact Us 📞</h1>
    <p class="text-gray-500 mt-2">We are here to help you 24/7</p>
  </div>

  <!-- MAIN CONTAINER -->
  <div class="max-w-6xl mx-auto mt-10 grid grid-cols-1 md:grid-cols-2 gap-10 p-6">

    <!-- CONTACT FORM -->
    <div class="bg-white p-6 rounded-2xl shadow-lg">

      <h2 class="text-2xl font-bold mb-4">Send Message</h2>

      <form class="space-y-4">

        <input type="text" placeholder="Your Name"
          class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-blue-500">

        <input type="email" placeholder="Your Email"
          class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-blue-500">

        <input type="text" placeholder="Subject"
          class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-blue-500">

        <textarea rows="5" placeholder="Your Message"
          class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-blue-500"></textarea>

        <button type="submit"
          class="w-full bg-blue-600 text-white py-3 rounded-lg hover:bg-blue-700 transition">
          Send Message 🚀
        </button>

      </form>

    </div>

    <!-- CONTACT INFO -->
    <div class="bg-white p-6 rounded-2xl shadow-lg">

      <h2 class="text-2xl font-bold mb-4">Contact Information</h2>

      <div class="space-y-4 text-gray-700">

        <p>📍 Address: Mithapur, Bihar, India</p>

        <p>📞 Phone: +91 98765 43210</p>

        <p>📧 Email: support@laptopstore.com</p>

        <p>⏰ Working Hours: 9 AM - 8 PM</p>

      </div>

      <!-- SOCIAL -->
      <div class="mt-6">
        <h3 class="font-bold mb-2">Follow Us</h3>

        <div class="flex gap-4 text-xl">
          <a href="#" class="text-blue-600">🌐</a>
          <a href="#" class="text-pink-600">📸</a>
          <a href="#" class="text-blue-400">🐦</a>
          <a href="#" class="text-green-600">💬</a>
        </div>
      </div>

    </div>

  </div>

  <!-- MAP STYLE SECTION -->
  <div class="max-w-6xl mx-auto mt-10 p-6">
    <div class="bg-black text-white p-10 rounded-2xl text-center shadow-lg">
      <h2 class="text-2xl font-bold">We are always available for you ❤️</h2>
      <p class="mt-2 text-gray-300">Fast response • Friendly support • 100% satisfaction</p>
    </div>
  </div>

  <!-- FOOTER -->
  <footer class="bg-black text-white text-center p-4 mt-10">
    © 2026 LaptopStore | All Rights Reserved
  </footer>

</body>
</html>