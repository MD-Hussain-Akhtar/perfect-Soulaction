<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>

  <!-- Tailwind CDN -->

</head>

<body class="bg-gray-100">

  <%- include('Navbar') %>

  <div class="max-w-6xl mx-auto px-4 py-8">

    <h1 class="text-3xl font-bold text-center mb-8 text-gray-800">
      ❤️ Favorites
    </h1>

    <% if (favorites.length === 0) { %>
      <p class="text-center text-gray-500">No favorites added yet.</p>
    <% } %>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">

      <% favorites.forEach(fav => { %>

        <div class="bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-xl transition">

          <img src="<%= fav.imageUrl %>" class="w-full h-48 object-cover" />

          <div class="p-4">

            <h3 class="text-lg font-bold text-gray-800 mb-2">
              <%= fav.productName %>
            </h3>

            <p class="text-gray-600 text-sm mb-3">
              <%= fav.description %>
            </p>

            <p class="text-xs text-gray-400 mb-4">
              ID: <%= fav.productId %>
            </p>

           <form action="/remove-favorite" method="POST">

  <input type="hidden" name="productId" value="<%= fav.productId %>">

  <button class="w-full bg-red-500 hover:bg-red-600 text-white py-2 rounded-xl transition">
    Remove
  </button>

</form>
          </div>

        </div>

      <% }) %>

    </div>

  </div>

</body>
</html>